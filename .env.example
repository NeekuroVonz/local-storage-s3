# Application
NODE_ENV=development
APP_NAME="Storage Platform"
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# Backend
BACKEND_PORT=4000
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN_REMEMBER=30d
BCRYPT_ROUNDS=12

# Database
DATABASE_URL=postgresql://storage:storage@localhost:5432/storage_platform?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# S3 / Garage (included in docker/docker-compose.dev.yml)
S3_ENDPOINT=http://localhost:3900
S3_REGION=garage
S3_ACCESS_KEY_ID=GK0011223344556677
S3_SECRET_ACCESS_KEY=dev-storage-secret-key-change-in-production
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_ENDPOINT=http://localhost:3900
GARAGE_ADMIN_ENDPOINT=http://localhost:3903
GARAGE_ADMIN_TOKEN=dev-garage-admin-token-not-for-production
CREDENTIALS_ENCRYPTION_KEY=
GARAGE_DEFAULT_BUCKET=storage
GARAGE_DEFAULT_ACCESS_KEY=GK0011223344556677
GARAGE_DEFAULT_SECRET_KEY=dev-storage-secret-key-change-in-production

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@storage.local

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
