# Application
NODE_ENV=production
APP_NAME="Storage Platform"
# Public UI URL (use server IP if clients are on LAN, not localhost)
APP_URL=http://10.0.68.57:3212
# Host ports mapped in docker/docker-compose.yml (container internal ports stay 3000/4000)
FRONTEND_PORT=3212
BACKEND_PORT=4013
GARAGE_S3_PORT=3900

# Backend (container listens on 4000; BACKEND_PORT above is the host mapping)
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN_REMEMBER=30d
BCRYPT_ROUNDS=12

# Database — only used for local dev (bun dev); Docker production uses compose defaults
DATABASE_URL=postgresql://storage:storage@localhost:5432/storage_platform?schema=public

# Redis — only used for local dev; Docker production uses service name "redis"
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# S3 / Garage — Docker production: use service names garage:* for internal endpoints
S3_ENDPOINT=http://garage:3900
S3_REGION=garage
S3_ACCESS_KEY_ID=GKyour-access-key
S3_SECRET_ACCESS_KEY=your-s3-secret-key
S3_FORCE_PATH_STYLE=true
# Public S3 URL for presigned links (server IP + GARAGE_S3_PORT)
S3_PUBLIC_ENDPOINT=http://10.0.68.57:3900
GARAGE_ADMIN_ENDPOINT=http://garage:3903
GARAGE_ADMIN_TOKEN=your-garage-admin-token-must-match-garage.toml
CREDENTIALS_ENCRYPTION_KEY=your-credentials-encryption-key
GARAGE_DEFAULT_BUCKET=storage
GARAGE_DEFAULT_ACCESS_KEY=GKyour-access-key
GARAGE_DEFAULT_SECRET_KEY=your-s3-secret-key

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@storage.local

# Frontend (baked at image build time — must match how browsers reach the API)
NEXT_PUBLIC_API_URL=http://10.0.68.57:4013/api/v1
